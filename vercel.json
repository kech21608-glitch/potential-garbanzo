{
  "functions": {
    "api/match.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/match_info",
      "dest": "/api/match.py"
    },
    {
      "src": "/health",
      "dest": "/api/match.py"
    },
    {
      "src": "/cache_stats",
      "dest": "/api/match.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/match.py"
    }
  ]
}
